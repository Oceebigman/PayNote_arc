      } else {
        setErrorMsg(e.message || 'Something went wrong.')
      }
    }
  }

  function handleCopyTx() {
    navigator.clipboard.writeText(txHash)
    setCopied(true)
    setTimeout(() => setCopied(false), 2000)
  }

  function handleCopyAddress() {
    navigator.clipboard.writeText(toAddress)
    setCopied(true)
    setTimeout(() => setCopied(false), 2000)
  }

  if (status === 'success') {
    return (
      <div className="flex flex-col items-center text-center gap-5 py-2">
        <div className="w-14 h-14 rounded-full flex items-center justify-center" style={{background: 'linear-gradient(135deg, #102A83, #1A44C4)'}}>
          <svg className="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2.5}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <div>
          <p className="text-xl font-bold text-gray-900 mb-1">Payment sent!</p>
          <p className="text-gray-400 text-sm">{amount} USDC · Arc Testnet</p>
        </div>
        <div className="w-full bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 text-left">
          <p className="text-xs font-semibold uppercase tracking-widest text-gray-300 mb-1.5">Transaction hash</p>
          <p className="text-gray-500 text-xs font-mono break-all leading-relaxed">{txHash}</p>
          <button onClick={handleCopyTx} className="mt-2 text-xs font-medium" style={{color: '#1A44C4'}}>

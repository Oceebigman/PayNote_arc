      request: (args: { method: string; params?: unknown[] }) => Promise<unknown>
    } | undefined

    if (!ethereum) {
      setStatus('error')
      setErrorMsg('No wallet detected. Please install MetaMask or another Web3 wallet.')
      return
    }

    try {
      setStatus('pending')
      setErrorMsg('')

      const accounts = await ethereum.request({ method: 'eth_requestAccounts' }) as string[]
      const from = accounts[0]

      const currentChain = await ethereum.request({ method: 'eth_chainId' }) as string

      if (currentChain.toLowerCase() !== ARC_CHAIN_ID.toLowerCase()) {
        setStatus('error')
        setErrorMsg('Please switch to Arc Testnet in your wallet, then try again.')
        return

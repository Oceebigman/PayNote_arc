# PayNote environment variables.
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# All NEXT_PUBLIC_ vars are exposed to the browser bundle — do NOT put
# secrets there. Server-only secrets have no prefix.

# ============================================================
# Database
# ============================================================

# Postgres connection string. Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://egcrypt:CHANGE_ME@localhost:5432/paynote_db

# ============================================================
# Application
# ============================================================

# Public canonical URL — used in receipts, webhooks, agent payment intents.
# Must match the actual domain the app is served from.
NEXT_PUBLIC_APP_URL=https://paynote.space

# Port Next.js listens on (behind nginx). If running standalone: use 3000.
PORT=3001

# ============================================================
# Admin
# ============================================================

# Required for /admin dashboard and admin-scoped API routes.
# Generate with: openssl rand -hex 32
# Without this, the admin dashboard returns 404 (not a helpful error).
ADMIN_SECRET=CHANGE_ME_TO_64_HEX_CHARS

# ============================================================
# Arc network (public — safe to expose to browser bundle)
# ============================================================

NEXT_PUBLIC_ARC_RPC=https://rpc.testnet.arc.network
NEXT_PUBLIC_CHAIN_ID=0x4cef52

# PayNote router contracts on Arc Testnet (verified live).
# v1: native USDC transfers.
# v2: multi-asset, split payments, token whitelist.
NEXT_PUBLIC_PAYNOTE_ROUTER=0x829fe116E221d14Db289623028c5AC6b2F30BD82
NEXT_PUBLIC_PAYNOTE_ROUTER_V2=0xc7190DBb23861b7dB15eED4326eBa33B0eeacEa4

# ============================================================
# Not currently used but reserved for future features
# ============================================================

# ANTHROPIC_API_KEY=  # Only if migrating Penny to LLM-powered mode.
                     # DO NOT set unless explicitly confirmed with account owner.
